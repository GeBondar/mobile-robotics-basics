<?xml version="1.0"?>
<robot name="flexible_robot">
  <material name="blue">
    <color rgba="0 0.2 0.8 1"/>
  </material>
  <material name="gray">
    <color rgba="0.45 0.45 0.45 1"/>
  </material>
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>
  <link name="head">
    <visual>
      <geometry>
        <sphere radius="0.18"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.18"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>
  <joint name="head_swivel" type="continuous">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="left_gripper">
    <visual>
      <geometry>
        <box size="0.08 0.25 0.08"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  <joint name="left_gripper_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_gripper"/>
    <origin xyz="0.35 0.18 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="10" velocity="1"/>
  </joint>
</robot>

<?xml version="1.0"?>
<robot name="materials">
  <material name="blue">
    <color rgba="0.0 0.2 0.8 1.0"/>
  </material>
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.6" radius="0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>
  <link name="head">
    <visual>
      <geometry>
        <sphere radius="0.25"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>
  <joint name="base_to_head" type="fixed">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="0 0 0.55" rpy="0 0 0"/>
  </joint>
</robot>

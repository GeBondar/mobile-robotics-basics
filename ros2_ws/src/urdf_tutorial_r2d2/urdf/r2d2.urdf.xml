<?xml version="1.0"?>
<robot name="course_r2d2">
  <material name="blue">
    <color rgba="0.0 0.2 0.8 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.02 0.02 0.02 1.0"/>
  </material>

  <link name="axis"/>

  <link name="body">
    <visual>
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.35" length="0.7"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.35" length="0.7"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.35" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.12" ixy="0" ixz="0" iyy="0.12" iyz="0" izz="0.08"/>
    </inertial>
  </link>

  <joint name="axis_to_body" type="fixed">
    <parent link="axis"/>
    <child link="body"/>
  </joint>

  <link name="head">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.32"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.32"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.04" ixy="0" ixz="0" iyy="0.04" iyz="0" izz="0.04"/>
    </inertial>
  </link>

  <joint name="swivel" type="continuous">
    <parent link="body"/>
    <child link="head"/>
    <origin xyz="0 0 0.75" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="camera">
    <visual>
      <geometry>
        <box size="0.12 0.08 0.08"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="tilt" type="revolute">
    <parent link="head"/>
    <child link="camera"/>
    <origin xyz="0.28 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.6" upper="0.2" effort="5" velocity="1"/>
  </joint>

  <link name="periscope">
    <visual>
      <geometry>
        <cylinder radius="0.04" length="0.35"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="periscope" type="prismatic">
    <parent link="head"/>
    <child link="periscope"/>
    <origin xyz="0 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.2" effort="5" velocity="0.5"/>
  </joint>
</robot>
